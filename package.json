{
  "name": "playground-cap-v1",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@cap-js/cds-types": "^0.15.0",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^5",
    "@cap-js/cds-typer": ">=0.1"
  },
  "scripts": {
    "start": "cds-serve",
    "w": "cds-ts w --profile hybrid"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": "xsuaa",
      "db": "hana"
    },
    "build": {
      "tasks": [
        {
          "for": "hana",
          "dest": "../db"
        },
        {
          "for": "nodejs"
        }
      ]
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
