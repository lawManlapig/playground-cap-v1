{
  "name": "playground-cap-v1",
  "version": "2.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.4.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "w": "cds-ts w --profile hybrid",
    "bdep": "rimraf resources mta_archives && mbt build --mtar a && cf deploy mta_archives/a.mtar --abort-on-error",
    "bdep_d": "rimraf resources mta_archives && mbt build --mtar a && cf deploy mta_archives/a.mtar --abort-on-error --delete-services",
    "bdep_": "mbt build --mtar a && cf deploy mta_archives/a.mtar --abort-on-error",
    "watch-employees-roster": "cds watch --open employeesroster/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy playground-cap-v1 --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-applicants-roster": "cds watch --open applicantsroster/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": "xsuaa",
      "db": "hana"
    },
    "build": {
      "tasks": [
        {
          "for": "hana",
          "dest": "../db"
        },
        {
          "for": "nodejs"
        }
      ]
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employees-roster",
    "app/applicants-roster"
  ]
}
